{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.fgl)|Edit(*.fgl)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-fgl.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
